# LawMind 本地开发环境变量配置
# 复制此文件为 .env 并填入实际值：
#   cp .env.example .env
#
# 注意: .env 和 application-dev.yml 已在 .gitignore 中排除，
# 不会提交到版本控制系统。

# MySQL 数据库密码
MYSQL_PASSWORD=your_mysql_password

# 阿里云百炼 DashScope API Key
# 获取地址: https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY=sk-your-api-key-here
